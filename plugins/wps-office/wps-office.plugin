#!name=WPS Office 每日签到
#!desc=每日签到、打卡领会员、天天抽奖、会员试用申请、限量爆款领取、小程序打卡。首次使用需打开 WPS APP 活动页抓取 Cookie。
#!author=MaYIHEI / mirrored by githunan
#!homepage=https://github.com/githunan/loon-plugins
#!icon=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/wps-office/app/wps/wps.png

[MITM]
hostname = personal-act.wps.cn

[Script]
http-request ^https:\/\/personal-act\.wps\.cn\/activity-rubik\/activity\/page_info tag=WPS Cookie, script-path=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/wps-office/app/wps/wps.cookie.js, requires-body=false, img-url=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/wps-office/app/wps/wps.png

cron "0 10 * * *" script-path=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/wps-office/app/wps/wps.js, tag=WPS签到, img-url=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/wps-office/app/wps/wps.png, enable=true
