#!name=WeTalk签到
#!desc=自动化签到加视频奖励，支持多账号。首次使用需打开 WeTalk APP 触发参数抓取。
#!author=ZenMoFiShi / mirrored by githunan
#!homepage=https://github.com/githunan/loon-plugins
#!icon=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/wetalk/assets/WeTalk.jpg

[MITM]
hostname = api.wetalkapp.com

[Script]
http-request ^https:\/\/api\.wetalkapp\.com\/app\/queryBalanceAndBonus script-path=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/wetalk/scripts/WeTalk.js, timeout=60, tag=WeTalk获取签到参数, img-url=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/wetalk/assets/WeTalk.jpg

cron "20 8,20 * * *" script-path=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/wetalk/scripts/WeTalk.js, tag=WeTalk签到, timeout=300, img-url=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/wetalk/assets/WeTalk.jpg, enable=true
