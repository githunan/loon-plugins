#!icon=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/assets/icon.jpg

[Rewrite]
^https?:\/\/[\w.-]+\/App\/Ad\/splashInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/noticeInfo reject-dict
^https?:\/\/[\w.-]+\/App\/IndexList\/homeFloatAd reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/activityInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/skitAdInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/countPopTotal reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/barsUserAdInfo reject-dict
^https?:\/\/[\w.-]+\/App\/ad\/config reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/vajraInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/bannerInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/bardCacheAdInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/barsIndexAdInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/comicAdInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/liveEventAdInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/novelAdInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Ad\/sportAdInfo reject-dict
^https?:\/\/[\w.-]+\/App\/Resource\/CommentAd\/show reject-dict

[Script]
http-response ^https?:\/\/[\w.-]+\/App\/Resource\/Config\/getNav script-path=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/js/TilingSales_getNav.js, requires-body=true, timeout=60, tag=瓜子影视净化, img-url=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/assets/icon.jpg
http-response ^https?:\/\/[\w.-]+\/App\/Ad\/barsPlayAdInfo script-path=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/js/TilingSales_getNav.js, requires-body=true, timeout=60, tag=瓜子影视净化, img-url=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/assets/icon.jpg
http-response ^https?:\/\/[\w.-]+\/App\/Ad\/playAdInfo script-path=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/js/TilingSales_getNav.js, requires-body=true, timeout=60, tag=瓜子影视净化, img-url=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/assets/icon.jpg
http-response ^https?:\/\/[\w.-]+\/App\/IndexPlay\/vodAdvertisement script-path=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/js/TilingSales_getNav.js, requires-body=true, timeout=60, tag=瓜子影视净化, img-url=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/assets/icon.jpg
http-response ^https?:\/\/[\w.-]+\/App\/Resource\/Vod\/showOne script-path=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/js/TilingSales_getNav.js, requires-body=true, timeout=60, tag=瓜子影视净化, img-url=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/assets/icon.jpg
http-response ^https?:\/\/[\w.-]+\/App\/Resource\/Vod\/vurlDetail script-path=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/js/TilingSales_getNav.js, requires-body=true, timeout=60, tag=瓜子影视净化, img-url=https://raw.githubusercontent.com/githunan/loon-plugins/main/plugins/tilingsales/assets/icon.jpg

